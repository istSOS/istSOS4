# istSOS4 (sorgente)
ISTSOS4_FROM_URL=https://source.example/v1.1
ISTSOS4_FROM_USER=source-user
ISTSOS4_FROM_PASSWORD=source-password

# Filtri opzionali sulla sorgente
NETWORK_FROM=
DATASTREAMS_FROM=
TIMESTAMP_START_FROM=
TIMESTAMP_END_FROM=

# istSOS4 (destinazione)
ISTSOS4_TO_URL=http://target.example/v1.1
ISTSOS4_TO_USER=target-user
ISTSOS4_TO_PASSWORD=target-password

# Filtri opzionali sulla destinazione
NETWORK_TO=
DATASTREAMS_TO=

# Gestione del valore "no data"
# IMPORT_NODATA=true  -> importa tutto (default)
# IMPORT_NODATA=false -> scarta le osservazioni il cui result vale NODATA_VALUE
IMPORT_NODATA=true
NODATA_VALUE=-999.9

# Verbosità dei log: DEBUG, INFO (default), WARNING, ERROR
LOG_LEVEL=INFO
