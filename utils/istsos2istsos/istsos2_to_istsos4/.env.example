# istSOS2 (sorgente)
ISTSOS2_URL=https://source.example/istsos2
ISTSOS2_USER=source-user
ISTSOS2_PASSWORD=source-password

# istSOS4 (destinazione)
ISTSOS4_URL=http://localhost:8019/v4/v1.1
ISTSOS4_USER=target-user
ISTSOS4_PASSWORD=target-password

# Gestione del valore "no data"
# IMPORT_NODATA=true  -> importa tutto (default)
# IMPORT_NODATA=false -> scarta le osservazioni il cui result vale NODATA_VALUE
IMPORT_NODATA=true
NODATA_VALUE=-999.9

# Verbosità dei log: DEBUG, INFO (default), WARNING, ERROR
LOG_LEVEL=INFO