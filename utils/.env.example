# Copy this file to utils/.env and edit the values for the server.

# Docker runtime
ISTSOS4_UTILS_IMAGE=istsos4-utils
DOCKER=/usr/bin/docker

# istSOS4 API
# If the container runs with --network host, localhost means the Docker host.
ISTSOS4_URL=http://localhost:8018/istsos4/v1.1
ISTSOS4_USERNAME=admin
ISTSOS4_PASSWORD=admin

# EyeOnWater import defaults
EYEONWATER_THING_ID=12
EYEONWATER_NETWORK_NAME=winca4ti
EYEONWATER_BBOX=6.116638,46.187437,6.963959,46.545639
EYEONWATER_LOOKBACK_DAYS=2

# Optional fixed API time window. Usually leave these empty for cron.
EYEONWATER_BEGIN=
EYEONWATER_END=

# Optional file paths for wrappers.
XLSX_PATH=
EYEONWATER_JSON_PATH=
